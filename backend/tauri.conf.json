{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scribe",
  "version": "0.1.0",
  "identifier": "com.chl84.scribe",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scribe",
        "width": 800,
        "height": 800,
        "minWidth": 300,
        "minHeight": 300,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
